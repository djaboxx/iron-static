{
  "instrument": "take5",
  "name": "Sequential Take 5",
  "source_manual": "Take-5-MIDI-Implementation_V2.pdf",
  "source_url": "https://sequential.com/wp-content/uploads/2025/07/Take-5-MIDI-Implementation_V2.pdf",
  "source_section": "MIDI Implementation Chart V2",
  "notes": [
    "MIDI Param Send/Receive must be set to CC or NRPN in globals — not both active simultaneously.",
    "NRPNs are preferred: CCs are 7-bit (0-127), NRPNs cover the full parameter range (e.g. FilterFreq NRPN 29 = 0-1023).",
    "CC 74 (Brightness) adds directly to filter cutoff frequency even when received as a standard controller.",
    "Mod Wheel, Foot Controller, Expression, Breath are directly assignable controllers in globals.",
    "Bank Select: 0-7 = User Banks 1-8; 8-15 = Factory Banks 1-8.",
    "NRPN format: CC99 (MSB param), CC98 (LSB param), CC6 (MSB value), CC38 (LSB value).",
    "Modulation routing: 16 mod slots (Mod1-Mod16), each with Source, Destination, and Amount NRPNs.",
    "Sequencer NRPNs: SeqOnOff=4198, SeqRecordArm=4199.",
    "Global NRPNs 4096-4122 cover master tuning, MIDI config, aftertouch, velocity curves, etc."
  ],
  "midi_channels": {
    "default": "1 (configurable via globals — or ALL to receive on all channels)"
  },
  "standard_controllers": {
    "description": "Fixed CC mappings active regardless of Param Rcv setting",
    "received": {
      "cc1":   { "name": "Mod Wheel",          "notes": "Directly assignable" },
      "cc4":   { "name": "Foot Controller",    "notes": "Assignable via Pedal Function" },
      "cc11":  { "name": "Expression",         "notes": "Assignable via Pedal/CV" },
      "cc32":  { "name": "Bank Select MSB",    "range": "0-15", "notes": "0-7=User 1-8, 8-15=Factory 1-8" },
      "cc64":  { "name": "Sustain/Damper",     "notes": "Holds envelopes in sustain" },
      "cc74":  { "name": "Brightness",         "notes": "Added directly to filter cutoff" },
      "cc121": { "name": "Reset All Controllers", "notes": "Clears all controllers, volume to max" },
      "cc123": { "name": "All Notes Off" }
    },
    "transmitted": {
      "cc1":   { "name": "Mod Wheel" },
      "cc2":   { "name": "Breath Controller", "notes": "When assigned to Pedal/CV" },
      "cc4":   { "name": "Foot Controller",   "notes": "When assigned to Pedal/CV" },
