        "highpass":      { "cc_msb": 89, "nrpn_msb": 2, "nrpn_lsb": 4, "range": "0-127" },
        "lowpass":       { "cc_msb": 90, "nrpn_msb": 2, "nrpn_lsb": 5, "range": "0-127" },
        "reverb_send":   { "cc_msb": 91, "nrpn_msb": 2, "nrpn_lsb": 6, "range": "0-127" },
        "mix_volume":    { "cc_msb": 92, "nrpn_msb": 2, "nrpn_lsb": 7, "range": "0-127" }
      }
    },
    "fx_reverb": {
      "description": "FX Reverb — sent on auto-channel",
