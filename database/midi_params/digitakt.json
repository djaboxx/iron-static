        "attack":          { "cc_msb": 112, "nrpn_msb": 2, "nrpn_lsb": 17, "range": "0-127" },
        "release":         { "cc_msb": 113, "nrpn_msb": 2, "nrpn_lsb": 18, "range": "0-127" },
        "makeup_gain":     { "cc_msb": 114, "nrpn_msb": 2, "nrpn_lsb": 19, "range": "0-127" },
        "ratio":           { "cc_msb": 115, "nrpn_msb": 2, "nrpn_lsb": 20, "range": "0-127" },
        "sidechain_source":{ "cc_msb": 116, "nrpn_msb": 2, "nrpn_lsb": 21, "range": "0-127" },
        "sidechain_filter":{ "cc_msb": 117, "nrpn_msb": 2, "nrpn_lsb": 22, "range": "0-127" },
        "dry_wet_mix":     { "cc_msb": 118, "nrpn_msb": 2, "nrpn_lsb": 23, "range": "0-127" },
        "pattern_volume":  { "cc_msb": 119, "nrpn_msb": 2, "nrpn_lsb": 24, "range": "0-127" }
