    "midi_track_val": {
      "description": "CC VAL parameters on FLTR page for MIDI tracks (not audio tracks)",
      "params": {
        "val1": { "cc_msb": 70 },
        "val2": { "cc_msb": 71 },
        "val3": { "cc_msb": 72 },
        "val4": { "cc_msb": 73 },
        "val5": { "cc_msb": 74 },
        "val6": { "cc_msb": 75 },
        "val7": { "cc_msb": 76 },
        "val8": { "cc_msb": 77 }
      }
    }
  },
  "iron_static_usage": {
    "primary_role": "Drum machine and MIDI sequencer hub — drives all external gear via MIDI tracks 1-8",
    "key_ccs_for_digitakt": [
      { "cc": 74, "name": "Filter Frequency", "use": "Parameter lock filter sweeps on audio tracks" },
      { "cc": 7,  "name": "Track Volume",     "use": "Volume automation on audio tracks" },
      { "cc": 10, "name": "Pan",              "use": "Stereo field automation" },
      { "cc": 82, "name": "Delay Send",       "use": "Throw to delay on hits" },
      { "cc": 83, "name": "Reverb Send",      "use": "Throw to reverb on hits" },
      { "cc": 109,"name": "LFO1 Depth",       "use": "Parameter lock LFO intensity for fills/transitions" }
    ]
  }
