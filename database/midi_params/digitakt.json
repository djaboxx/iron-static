        "shelving_freq": { "cc_msb": 26, "nrpn_msb": 2, "nrpn_lsb": 10, "range": "0-127" },
        "shelving_gain": { "cc_msb": 27, "nrpn_msb": 2, "nrpn_lsb": 11, "range": "0-127" },
        "highpass":      { "cc_msb": 28, "nrpn_msb": 2, "nrpn_lsb": 12, "range": "0-127" },
        "lowpass":       { "cc_msb": 29, "nrpn_msb": 2, "nrpn_lsb": 13, "range": "0-127" },
        "pre_post_comp": { "cc_msb": 30, "nrpn_msb": 2, "nrpn_lsb": 14, "range": "0-1" },
        "mix_volume":    { "cc_msb": 31, "nrpn_msb": 2, "nrpn_lsb": 15, "range": "0-127" }
      }
    },
