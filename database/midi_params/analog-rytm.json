{
  "instrument": "analog-rytm",
  "name": "Elektron Analog Rytm MKII",
  "source_manual": "Analog-Rytm-MKII-User-Manual_ENG_OS1.72_250130.pdf",
  "source_section": "Appendix C: MIDI (pp. 88-97)",
  "notes": [
    "Per-track CCs (TRIG, EUCLIDEAN, KIT, SYNTH, SAMPLE, FILTER, AMP, LFO) are sent on each track's individual MIDI channel (default: tracks 1-12 → channels 1-12).",
    "FX CCs (Delay, Reverb, Distortion, Compressor) are sent on the auto-channel (default ch 13).",
    "CC numbers in the FX section overlap with per-track SYNTH/SAMPLE sections — they operate on different MIDI channels.",
    "NRPN MSB 0 = Performance parameters. NRPN MSB 1 = per-track parameters. NRPN MSB 2 = FX parameters. NRPN MSB 3 = Trig/Euclidean parameters.",
    "Synth Parameters 1-8 (CC 16-23) are machine-dependent — exact parameter names differ per machine type (see machines section).",
    "LFO Depth (CC 109 MSB + CC 118 LSB) is high-resolution.",
    "MIDI Note Triggers: C0 (MIDI note 0) = Track 1 through B0 (MIDI note 11) = Track 12. C1-B4 (notes 12-59) = chromatic pitch trigger of the active track.",
    "Analog Rytm does not support MIDI SysEx program dump — use CC/NRPN for real-time control.",
    "Track Machine Type (CC 15) selects the synthesis engine for a track — see machines section for values."
  ],
  "midi_channels": {
    "auto_channel": "Channel 13 (default, configurable). Used for FX and global CCs.",
    "track_channels": "Channels 1-12 (one per drum track). Used for per-track TRIG/SYNTH/FILTER/AMP/LFO CCs.",
    "performance_channel": "Auto-channel. Performance pads send on auto-channel."
  },
  "midi_note_triggers": {
    "description": "MIDI notes sent to Analog Rytm trigger tracks or chromatic pitches",
    "track_triggers": {
      "C0 (0)":  "Track 1", "C#0 (1)": "Track 2",  "D0 (2)":  "Track 3",
      "D#0 (3)": "Track 4", "E0 (4)":  "Track 5",  "F0 (5)":  "Track 6",
      "F#0 (6)": "Track 7", "G0 (7)":  "Track 8",  "G#0 (8)": "Track 9",
      "A0 (9)":  "Track 10","A#0 (10)":"Track 11", "B0 (11)": "Track 12"
    },
    "chromatic_range": "C1 (12) through B4 (59) — chromatic pitch trigger of the active track"
  },
