  "iron_static_usage": {
    "primary_role": "Analog percussion engine — 12 drum tracks, each with its own synthesis machine. Driven standalone or via MIDI from DAW.",
    "key_ccs_for_live_control": [
      { "cc": 74, "name": "Filter Freq",     "use": "Real-time filter opens/closes on drum hits" },
      { "cc": 7,  "name": "Track Volume",    "use": "Per-track volume automation" },
      { "cc": 82, "name": "Delay Send",      "use": "Throw individual drums into delay on fills" },
      { "cc": 83, "name": "Reverb Send",     "use": "Throw individual drums into reverb" },
      { "cc": 81, "name": "Overdrive",       "use": "Drive individual tracks for aggression" },
      { "cc": 92, "name": "Active Scene",    "use": "Scene morphing via Performance mode" },
      { "cc": 78, "name": "Comp Threshold",  "use": "Auto: FX compressor pumping effect" }
    ],
    "notes": "Per-track FX sends (CC 82/83) on each track's channel allow individual drum routing to the global Delay/Reverb. Performance pads (CC 35-46) are ideal for real-time mix morphs — wire them to Ableton via auto-channel."
  }
}
