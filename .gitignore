# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Ableton Live
*.als.bak
Backup/

# Audio (large binaries — track with Git LFS instead)
*.wav
*.aiff
*.aif
*.mp3
*.flac
*.ogg
*.m4a

# Generated audio from Lyria/forge — never committed, always GCS
# Spec .md files in audio/generated/specs/ ARE committed (they're text)
audio/generated/*.wav
audio/generated/*.mp3
audio/generated/*.aiff
audio/generated/*.aif
audio/generated/*.flac
# Slices from chop_and_rack.py — WAV slices go to GCS, metadata JSON and .adg are committed
audio/generated/slices/**/*.wav
audio/generated/slices/**/*.mp3
# Ableton Analysis Files — auto-generated sidecar files, never committed
**/*.asd

# PDF manuals are tracked (small and essential)
# Exclude large sample packs dropped here by accident
audio/samples/**/*.zip
audio/samples/**/*.rar

# MIDI (tracked normally)
# *.mid — intentionally not ignored

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Secrets / credentials
*.token
credentials*.json
token*.json
.env
.env.*

# Terraform — never commit state (contains plaintext secrets) or provider cache
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfstate.*.backup
terraform/gcs.tfbackend
terraform/*.tflog
terraform/**/*.tflog
# terraform/.terraform.lock.hcl is intentionally committed (provider version lock)

# VS Code
.vscode/settings.json
.vscode/launch.json

# VS Code extension build output
vscode-extension/*/out/
vscode-extension/*/node_modules/
vscode-extension/*/*.vsix

# Stream Deck plugin build output
streamdeck/plugin/node_modules/
streamdeck/plugin/com.iron-static.bridge.sdPlugin/bin/
# Keep manifest.json, ui/, imgs/ — only exclude compiled JS
# (imgs are placeholder PNGs, kept so the manifest resolves locally)

# Logs
*.log
database/iron_static.db

# Manufacturer manuals — copyrighted, not redistributable. Store locally only.
instruments/*/manuals/*.pdf

# Runtime session dumps — not useful in a public repo
outputs/Ventura_*
outputs/ventura_*
outputs/live_state.json
outputs/repo_health.json
outputs/audio_intake_manifest.json
outputs/audio_analysis/
outputs/midi_clips/
outputs/rag/
outputs/social/*.mp4
credentials/
