# Audio files live in GCS (via gcs-sync workflow), NOT in git or LFS.
# The pre-commit hook blocks staged audio files that aren't in database/gcs_manifest.json.
# These attributes ensure git treats them as binary (no diff/merge) if somehow staged.
*.wav -text
*.aiff -text
*.aif -text
*.mp3 -text
*.flac -text
*.ogg -text
*.m4a -text

# Ableton sessions — committed directly (typically < 1 MB). Large sessions go to GCS.
*.als -text
*.alp -text

# PDF manuals live in GCS (via gcs-sync). The pre-commit hook blocks staged PDFs
# that are not in database/gcs_manifest.json.
*.pdf -text

# MIDI tracked normally as text-adjacent binary
*.mid -text
*.midi -text

# Normalize line endings
*.md text eol=lf
*.py text eol=lf
*.json text eol=lf
